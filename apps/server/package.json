{
  "name": "@graphitemd/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node ace serve --hmr",
    "start": "node build/bin/server.js",
    "build": "node ace build",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
