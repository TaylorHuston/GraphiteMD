{
  "name": "anthracitemd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": { "node": ">=24" },
  "scripts": {
    "dev": "pnpm --parallel --filter @anthracitemd/server --filter @anthracitemd/web dev",
    "dev:server": "pnpm --filter @anthracitemd/server dev",
    "dev:web": "pnpm --filter @anthracitemd/web dev",
    "start": "pnpm --filter @anthracitemd/server start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm --filter @anthracitemd/server build",
    "storybook": "pnpm --filter @anthracitemd/web storybook",
    "build-storybook": "pnpm --filter @anthracitemd/web build-storybook",
    "test:storybook": "pnpm --filter @anthracitemd/web test:storybook",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@playwright/test": "^1.58.2",
    "oxlint": "^1.71.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
