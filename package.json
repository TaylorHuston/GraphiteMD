{
  "name": "graphitemd",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": { "node": ">=24" },
  "scripts": {
    "dev": "pnpm --parallel --filter @graphitemd/server --filter @graphitemd/web dev",
    "dev:server": "pnpm --filter @graphitemd/server dev",
    "dev:web": "pnpm --filter @graphitemd/web dev",
    "start": "pnpm --filter @graphitemd/server start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm --filter @graphitemd/server build",
    "storybook": "pnpm --filter @graphitemd/web storybook",
    "build-storybook": "pnpm --filter @graphitemd/web build-storybook",
    "test:storybook": "pnpm --filter @graphitemd/web test:storybook",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@playwright/test": "^1.58.2",
    "oxlint": "^1.71.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
